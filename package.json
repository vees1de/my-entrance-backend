    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "prisma": "^5.18.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
